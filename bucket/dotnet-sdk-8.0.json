{
  "version": "8.0.422",
  "description": ".NET SDK 8.0",
  "homepage": "https://dotnet.microsoft.com/",
  "license": "MIT",
  "architecture": {
    "32bit": {
      "url": "https://dotnetcli.blob.core.windows.net/dotnet/Sdk/8.0.422/dotnet-sdk-8.0.422-win-x86.exe"
    },
    "64bit": {
      "url": "https://dotnetcli.blob.core.windows.net/dotnet/Sdk/8.0.422/dotnet-sdk-8.0.422-win-x64.exe"
    }
  },
  "depends": "dark",
  "bin": "dotnet.exe",
  "env_set": {
    "DOTNET_ROOT": "$dir"
  },
  "installer": {
    "script": [
      "Expand-DarkArchive \"$dir\\$fname\" \"$dir\\extracted\" -Removal",
      "Get-ChildItem \"$dir\\extracted\\AttachedContainer\\*.msi\" | ForEach-Object { Expand-MsiArchive $_ \"$dir\" }",
      "Move-Item \"$dir\\dotnet\\*\" \"$dir\" -Force",
      "@('dotnet', 'extracted') | ForEach-Object { Remove-Item \"$dir\\$_\" -Recurse }"
    ]
  },
  "checkver": {
    "url": "https://dotnetcli.blob.core.windows.net/dotnet/release-metadata/releases-index.json",
    "jsonpath": "$.releases-index[?(@['channel-version']=='8.0')]['latest-sdk']"
  },
  "autoupdate": {
    "architecture": {
      "32bit": {
        "url": "https://dotnetcli.blob.core.windows.net/dotnet/Sdk/$version/dotnet-sdk-$version-win-x86.exe"
      },
      "64bit": {
        "url": "https://dotnetcli.blob.core.windows.net/dotnet/Sdk/$version/dotnet-sdk-$version-win-x64.exe"
      }
    },
    "hash": {
      "mode": "extract",
      "url": "https://dotnetcli.blob.core.windows.net/dotnet/checksums/$version-sha.txt"
    }
  },
  "notes": "The .NET SDK contains the runtime, SDK, and CLI tools required to build applications."
}
